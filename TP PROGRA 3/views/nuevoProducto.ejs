<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <title>Nuevo Producto</title>

    <link rel="stylesheet" href="/css/admin.css">

</head>

<body>

<header>

    <h1>PeriTech Store - Nuevo Producto</h1>

</header>

<main>

<% if (typeof error !== "undefined") { %>

<div class="mensaje-error">

    <%= error %>

</div>

<% } %>

<form
    action="/admin/nuevo"
    method="POST"
    enctype="multipart/form-data">

    <p>Nombre</p>

    <input
        type="text"
        name="nombre"
        required>

    <p>Precio</p>

    <input
        type="number"
        name="precio"
        required>

    <p>Descripción</p>

    <input
        type="text"
        name="descripcion"
        required>

    <p>Categoría</p>

    <select name="categoria">

        <option>Teclados</option>
        <option>Mouses</option>
        <option>Monitores</option>
        <option>Auriculares</option>

    </select>

    <p>Imagen</p>

    <input
        type="file"
        name="imagen"
        accept="image/*"
        required>

    <br><br>

    <button class="btn">

        Guardar Producto

    </button>

</form>

</main>

</body>

</html>